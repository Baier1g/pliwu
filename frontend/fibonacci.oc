main(50, "v");

func fibbonaci(int n) -> int {
    if (n <= 1) {
        return n;
    }
    return fibbonaci(n - 1) + fibbonaci(n - 2);
}

func main(int a, char c) {
    fib_util(20);
}

func fib_util(int n) -> void {
    if (n == 0) {
        return;
    }
    fib_util(n - 1);
    print(fibbonaci(n));
}
