Grammar

    0 $accept: module $end

    1 module: ε
    2       | module declaration
    3       | module error

    4 declaration: varDeclaration
    5            | statement
    6            | funcDefinition

    7 varDeclaration: type identifier ';'
    8               | type identifier declarator ';'
    9               | type identifier T_ASSIGN conditionalExpression ';'
   10               | type identifier initializerDim T_ASSIGN arrayInitializer ';'
   11               | error ';'

   12 initializerDim: T_LEFT_BRACKET T_RIGHT_BRACKET
   13               | initializerDim T_LEFT_BRACKET T_RIGHT_BRACKET

   14 declarator: T_LEFT_BRACKET expression T_RIGHT_BRACKET
   15           | declarator T_LEFT_BRACKET expression T_RIGHT_BRACKET

   16 arrayInitializer: T_LEFT_BRACE initializerList T_RIGHT_BRACE

   17 initializerList: ε
   18                | initializerValue
   19                | initializerList T_COMMA initializerValue

   20 initializerValue: primary
   21                 | arrayInitializer

   22 type: T_INT_TYPE
   23     | T_CHAR_TYPE
   24     | T_BOOL_TYPE
   25     | T_VOID_TYPE
   26     | T_STRING_TYPE

   27 funcDefinition: T_FUNC function

   28 function: identifier T_LEFT_PAREN parameters T_RIGHT_PAREN returnType block

   29 returnType: ε
   30           | T_ARROW type

   31 parameters: ε
   32           | type identifier
   33           | type initializerDim identifier
   34           | parameters T_COMMA type identifier

   35 args: ε
   36     | assignExpression
   37     | args T_COMMA assignExpression

   38 statement: ifStatement
   39          | loopStatement
   40          | returnStatement
   41          | printStatement
   42          | expressionStatement

   43 ifStatement: T_IF T_LEFT_PAREN expression T_RIGHT_PAREN block else

   44 loopStatement: whileLoop

   45 whileLoop: T_WHILE T_LEFT_PAREN assignExpression T_RIGHT_PAREN block

   46 else: ε
   47     | T_ELSE block

   48 returnStatement: T_RETURN expression ';'
   49                | T_RETURN ';'

   50 printStatement: T_PRINT T_LEFT_PAREN expression T_RIGHT_PAREN ';'

   51 block: T_LEFT_BRACE blockBody T_RIGHT_BRACE

   52 blockBody: ε
   53          | blockBody declaration
   54          | blockBody error

   55 expressionStatement: expression ';'

   56 expression: assignExpression

   57 assignExpression: conditionalExpression
   58                 | identifier T_ASSIGN expression
   59                 | identifier declarator T_ASSIGN expression

   60 conditionalExpression: logicalAND

   61 logicalAND: logicalOR
   62           | logicalAND T_AND logicalOR

   63 logicalOR: relationalExpression
   64          | logicalOR T_OR relationalExpression

   65 relationalExpression: arithmeticExpression
   66                     | relationalExpression T_EQUALS arithmeticExpression
   67                     | relationalExpression T_NEQUALS arithmeticExpression
   68                     | relationalExpression '<' arithmeticExpression
   69                     | relationalExpression '>' arithmeticExpression
   70                     | relationalExpression T_LESS_EQ arithmeticExpression
   71                     | relationalExpression T_GREATER_EQ arithmeticExpression

   72 arithmeticExpression: multiplicativeExpression
   73                     | arithmeticExpression '+' multiplicativeExpression
   74                     | arithmeticExpression '-' multiplicativeExpression

   75 multiplicativeExpression: castExpression
   76                         | multiplicativeExpression '*' castExpression
   77                         | multiplicativeExpression '/' castExpression

   78 castExpression: unaryExpression

   79 unaryExpression: postfixExpression
   80                | '-' postfixExpression
   81                | '!' postfixExpression

   82 postfixExpression: primary
   83                  | postfixExpression T_LEFT_PAREN args T_RIGHT_PAREN
   84                  | postfixExpression T_LEFT_PAREN error T_RIGHT_PAREN
   85                  | identifier declarator

   86 identifier: T_IDENTIFIER

   87 primary: T_INT
   88        | T_CHAR
   89        | T_BOOL
   90        | T_STRING
   91        | T_LEFT_PAREN expression T_RIGHT_PAREN
   92        | T_LEFT_PAREN error T_RIGHT_PAREN
   93        | identifier


