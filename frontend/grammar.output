Grammar

    0 $accept: module $end

    1 module: ε
    2       | module declaration

    3 declaration: varDeclaration
    4            | statement
    5            | funcDefinition

    6 varDeclaration: type identifier ';'
    7               | type identifier declarator ';'
    8               | type identifier T_ASSIGN conditionalExpression ';'
    9               | type identifier initializerDim T_ASSIGN arrayInitializer ';'
   10               | error ';'

   11 initializerDim: T_LEFT_BRACKET T_RIGHT_BRACKET
   12               | initializerDim T_LEFT_BRACKET T_RIGHT_BRACKET

   13 declarator: T_LEFT_BRACKET expression T_RIGHT_BRACKET
   14           | declarator T_LEFT_BRACKET expression T_RIGHT_BRACKET

   15 arrayInitializer: T_LEFT_BRACE initializerList T_RIGHT_BRACE

   16 initializerList: ε
   17                | initializerValue
   18                | initializerList T_COMMA initializerValue

   19 initializerValue: primary
   20                 | arrayInitializer

   21 type: T_INT_TYPE
   22     | T_CHAR_TYPE
   23     | T_BOOL_TYPE
   24     | T_VOID_TYPE
   25     | T_STRING_TYPE

   26 funcDefinition: T_FUNC function

   27 function: identifier T_LEFT_PAREN parameters T_RIGHT_PAREN returnType block

   28 returnType: ε
   29           | T_ARROW type

   30 parameters: ε
   31           | type identifier
   32           | type initializerDim identifier
   33           | parameters T_COMMA type identifier

   34 args: ε
   35     | assignExpression
   36     | args T_COMMA assignExpression

   37 statement: ifStatement
   38          | loopStatement
   39          | returnStatement
   40          | printStatement
   41          | expressionStatement

   42 ifStatement: T_IF T_LEFT_PAREN expression T_RIGHT_PAREN block else

   43 loopStatement: whileLoop

   44 whileLoop: T_WHILE T_LEFT_PAREN assignExpression T_RIGHT_PAREN block

   45 else: ε
   46     | T_ELSE block

   47 returnStatement: T_RETURN expression ';'
   48                | T_RETURN ';'

   49 printStatement: T_PRINT T_LEFT_PAREN expression T_RIGHT_PAREN ';'

   50 block: T_LEFT_BRACE blockBody T_RIGHT_BRACE

   51 blockBody: ε
   52          | blockBody declaration

   53 expressionStatement: expression ';'

   54 expression: assignExpression

   55 assignExpression: conditionalExpression
   56                 | identifier T_ASSIGN expression
   57                 | identifier declarator T_ASSIGN expression

   58 conditionalExpression: logicalAND

   59 logicalAND: logicalOR
   60           | logicalAND T_AND logicalOR

   61 logicalOR: relationalExpression
   62          | logicalOR T_OR relationalExpression

   63 relationalExpression: arithmeticExpression
   64                     | relationalExpression T_EQUALS arithmeticExpression
   65                     | relationalExpression T_NEQUALS arithmeticExpression
   66                     | relationalExpression '<' arithmeticExpression
   67                     | relationalExpression '>' arithmeticExpression
   68                     | relationalExpression T_LESS_EQ arithmeticExpression
   69                     | relationalExpression T_GREATER_EQ arithmeticExpression

   70 arithmeticExpression: multiplicativeExpression
   71                     | arithmeticExpression '+' multiplicativeExpression
   72                     | arithmeticExpression '-' multiplicativeExpression

   73 multiplicativeExpression: castExpression
   74                         | multiplicativeExpression '*' castExpression
   75                         | multiplicativeExpression '/' castExpression

   76 castExpression: unaryExpression

   77 unaryExpression: postfixExpression
   78                | '-' postfixExpression
   79                | '!' postfixExpression

   80 postfixExpression: primary
   81                  | postfixExpression T_LEFT_PAREN args T_RIGHT_PAREN
   82                  | postfixExpression T_LEFT_PAREN error T_RIGHT_PAREN
   83                  | identifier declarator

   84 identifier: T_IDENTIFIER

   85 primary: T_INT
   86        | T_CHAR
   87        | T_BOOL
   88        | T_STRING
   89        | T_LEFT_PAREN expression T_RIGHT_PAREN
   90        | T_LEFT_PAREN error T_RIGHT_PAREN
   91        | identifier


