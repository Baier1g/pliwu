func insertion_sort(int[] a, int length) -> void {
    int i = 1;
    while (i < length) {
        int key = a[i];
        int j = i - 1;

        while (j >= 0 && a[j] > key) {
            a[j + 1] = a[j];
            j = j - 1;
        }
        a[j + 1] = key;
        i = i + 1;
    }
    return;
}