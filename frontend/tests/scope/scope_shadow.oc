func main() {
    int a = 1;
    int b = 2;
    int c = 3;
    print(a);
    print(b);
    print(c);

    if (true) {
        int a = 10;
        int b = 20;
        int c = 30;
        print(a);
        print(b);
        print(c);
    }

    if (true) {
        char a = 'a';
        char b = 'b';
        char c = 'c';
        print(a);
        print(b);
        print(c);
    }

    print(a);
    print(b);
    print(c);

    if (true) {
        a = 100;
        b = 200;
        c = 300;
    }
    print(a);
    print(b);
    print(c);
}