func parameter_test(int h, int i, int j, int k, int l, int m, int n) {
    int a1 = i;
    int bcc = j;
    int a = bcc;
    if (a == bcc) {
        int a = 33;
        int b = 2;
    } else {
        int q = 4;
    }
    a = ((7+5) * (7 - 3)) * ((50 - 20) * (2 + 4)) + bcc - a1;
    print(a);
    h = dummy(a, bcc) / dummy(bcc, a);
    n = 700 + gucci + grum + grim;
    print(n);
    print(dum_rec(10));
