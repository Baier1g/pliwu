func fibonacci(int n) -> int {
    if (n <= 1) {
        return n;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

func main() {
    fib_util(10);
    return;
}

func fib_util(int n) -> void {
    if (n == 0) {
        return;
    }
    fib_util(n - 1);
    print(fibonacci(n));
    return;
}
