func main() {
    int a[10];
    print(a);
    print(a[0]);
    int i = 10;
    int j = 0;
    while (i > 0) {
        a[j] = i;
        print(a[j]);
        i = i - 1;
        j = j + 1;
        print(a[j-1]);
    }
    while (i < 10) {
        print(a[i]);
        i = i + 1;
    }
    print(a[9]);
    print(a[2]);
    int b[20][10];
    //print(100);
    //insertion_sort(a, 10);
}

